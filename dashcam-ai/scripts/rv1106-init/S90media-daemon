#!/bin/sh
# /etc/init.d/S90media-daemon
# Buildroot init script (SysV-style, compatible with procd)
# Copied to device by deploy-rockchip.sh

DAEMON=/usr/bin/media-daemon
PIDFILE=/var/run/media-daemon.pid
LOG=/var/log/media-daemon.log

export RUST_LOG=info
export LD_LIBRARY_PATH=/usr/lib:$LD_LIBRARY_PATH

start() {
    echo "Starting media-daemon..."
    mkdir -p /var/run/dashcam /mnt/emmc/loop /mnt/emmc/evidence
    start-stop-daemon -S -b \
        --exec "$DAEMON" \
        --pidfile "$PIDFILE" \
        --make-pidfile \
        -- >> "$LOG" 2>&1
    echo "media-daemon started (pid $(cat $PIDFILE))"
}

stop() {
    echo "Stopping media-daemon..."
    start-stop-daemon -K \
        --pidfile "$PIDFILE" \
        --retry TERM/5/KILL/2
    rm -f "$PIDFILE"
    echo "media-daemon stopped"
}

restart() {
    stop
    sleep 1
    start
}

status() {
    if [ -f "$PIDFILE" ] && kill -0 "$(cat $PIDFILE)" 2>/dev/null; then
        echo "media-daemon is running (pid $(cat $PIDFILE))"
    else
        echo "media-daemon is NOT running"
        exit 1
    fi
}

case "$1" in
    start)   start   ;;
    stop)    stop    ;;
    restart) restart ;;
    status)  status  ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac
